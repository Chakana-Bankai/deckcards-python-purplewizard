{
  "version": "chakana_art_style_lock_v2",
  "style_mode": "illustrated_readable",
  "status": "active",
  "description": "Locks card art to an illustrated readable target: strong subject, clear object, faction identity, layered scene support, and higher surface richness while preserving runtime legibility and frame compatibility.",
  "principles": {
    "silhouette_first": true,
    "template_driven_subjects": true,
    "freeform_geometry_disabled": false,
    "hard_edge_props_required": true,
    "material_rendering_level": "mid_to_high",
    "scene_detail_subordinate_to_subject": true,
    "premium_illustration_not_required": false,
    "card_role_readability_required": true,
    "faction_color_readability_required": true,
    "frame_compatibility_required": true,
    "clean_composition_required": true,
    "subject_costume_detail_required": true,
    "distinct_family_templates_required": true,
    "object_material_finish_required": true
  },
  "component_priorities": [
    "subject_legibility",
    "subject_template_specificity",
    "material_readability",
    "prop_identity",
    "card_role_readability",
    "faction_palette_clarity",
    "frame_compatibility",
    "template_binding",
    "silhouette_hierarchy",
    "prop_glyph_clarity",
    "background_support_only"
  ],
  "deferred_capabilities": [
    "gpu_acceleration",
    "freeform_humanoid_generation"
  ],
  "target_quality": "illustrated_readable_production"
}
