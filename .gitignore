# Python
__pycache__/
*.pyc
*.pyo

# Test/cache
.pytest_cache/

# Virtual envs

.venv/
game/.venv/
game\\.venv/

# Auto-generated runtime binaries (keep data/docs JSON source files versioned)
game/assets/music/*.wav
game/assets/music/*.ogg
game/assets/sprites/cards/*.png
game/assets/sprites/enemies/*.png
game/assets/**/generated_*

# Runtime fonts and cache-like binaries
game/assets/**/*.ttf

# Keep placeholder keepfiles
!game/assets/**/.gitkeep

# Legacy prompt text artifacts
game/data/card_prompt.txt
game/data/card_prompts.txt



# Dev workflow flags/caches
.regen_flag
tools/__pycache__/
# Logs
*.log
logs/

# Runtime caches/temp
game/assets/.cache/
game/data/.cache/
game/assets/tmp/
*_autogen_tmp*

# Local runtime settings (use settings.default.json as tracked base)
game/data/settings.json

# Optional dev flags
.regen_flag

# Keep final shipped assets versioned (do NOT ignore)
!game/assets/sprites/cards/*.png
!game/assets/sprites/enemies/*.png
!game/assets/music/*.wav
!game/assets/**/.gitkeep
