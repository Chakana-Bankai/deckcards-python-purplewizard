# Binary assets (never merge line-by-line)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary

# Audio
*.wav binary
*.ogg binary
*.mp3 binary

# Fonts
*.ttf binary
*.otf binary

# Prevent diff noise
*.png -diff
*.wav -diff
*.ogg -diff
*.mp3 -diff

# JSON (allow normal merge)
*.json text merge=union

# Python
*.py text diff=python