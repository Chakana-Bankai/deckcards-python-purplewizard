# Generated manifests: reduce merge conflict noise
game/data/art_manifest*.json merge=ours linguist-generated=true
game/data/bgm_manifest.json merge=ours linguist-generated=true
game/data/biome_manifest.json merge=ours linguist-generated=true
game/data/prompt_manifest.json merge=ours linguist-generated=true

# Prompt payload can be generated by tooling
game/data/card_prompts.json linguist-generated=true
# Binary assets
*.png binary
*.wav binary

# Derived manifests/prompts: prefer local side during merges
game/data/*manifest*.json merge=ours
game/data/*_prompts.json merge=ours
game/data/prompt_manifest.json merge=ours
game/data/biome_manifest.json merge=ours
